# PDF Server Configuration
DEBUG=false #true
FLASK_ENV=production #production

PORT=5000
HOST=0.0.0.0

# PDF Settings
DEFAULT_PAGE_SIZE=A4
DEFAULT_ORIENTATION=portrait

# CORS Settings
CORS_ORIGINS=*

# Max template file size (5MB)
MAX_TEMPLATE_SIZE=5242880

# ========================================
# Oracle Database Configuration
# ========================================

# Enable Oracle connectivity (set to 'true' to enable)
ORACLE_ENABLED=true

# Oracle credentials
ORACLE_USER=afaaq_as_rpt
ORACLE_PASSWORD=AfrptMa_615

# Connection method 1: Use DSN string
# Format: host:port/service_name  or TNS name
# ORACLE_DSN=localhost:1521/ORCLPDB1

# Connection method 2: Use individual settings (if DSN is not set)
ORACLE_HOST=horizonstek.ddns.net
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=horizonpdb
# ORACLE_SID=ORCL  # Use SID instead of service name if needed

# Connection Pool Settings
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5
ORACLE_POOL_INCREMENT=1

# Query timeout in seconds
ORACLE_QUERY_TIMEOUT=30